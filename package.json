{
  "name": "pokemon-go",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "assets:images": "node scripts/generate-images.mjs",
    "start": "npm run assets:images && ng serve",
    "build": "npm run assets:images && ng build",
    "build-github": "npm run assets:images && ng build --configuration production --output-path=dist/pokemon-go",
    "watch": "npm run assets:images && ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^22.0.1",
    "@angular/common": "^22.0.1",
    "@angular/compiler": "^22.0.1",
    "@angular/core": "^22.0.1",
    "@angular/forms": "^22.0.1",
    "@angular/platform-browser": "^22.0.1",
    "@angular/platform-browser-dynamic": "^22.0.1",
    "@angular/router": "^22.0.1",
    "@angular/service-worker": "^22.0.1",
    "@ngrx/signals": "^21.1.0",
    "lz-string": "^1.5.0",
    "prettier": "^3.6.2",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "utilitish": "^0.0.23",
    "zone.js": "^0.15.1"
  },
  "devDependencies": {
    "@angular/build": "^22.0.1",
    "@angular/cli": "^22.0.1",
    "@angular/compiler-cli": "^22.0.1",
    "@types/jasmine": "^5.1.12",
    "istanbul-lib-instrument": "^6.0.3",
    "jasmine-core": "^5.10.0",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.1",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.1.0",
    "typescript": "^6.0.3"
  }
}
